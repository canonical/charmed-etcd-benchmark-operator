{
  "title": "Etcd Benchmark Overview",
  "uid": "etcd_benchmark_dashboard",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "test_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "definition": "label_values(etcd_benchmark_iteration, test_id)",
        "query": {
          "query": "label_values(etcd_benchmark_iteration, test_id)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "label": "Test ID"
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Throughput (RPS)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "etcd_benchmark_throughput_rps{test_id=~\"$test_id\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "legendFormat": "{{test_id}} {{op_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average Latency (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "etcd_benchmark_average_latency_seconds{test_id=~\"$test_id\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "legendFormat": "{{test_id}} {{op_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p50 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "etcd_benchmark_latency_seconds{quantile=\"0.50\", test_id=~\"$test_id\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "legendFormat": "{{test_id}} {{op_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p90 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "etcd_benchmark_latency_seconds{quantile=\"0.90\", test_id=~\"$test_id\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "legendFormat": "{{test_id}} {{op_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p99 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "etcd_benchmark_latency_seconds{quantile=\"0.99\", test_id=~\"$test_id\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "legendFormat": "{{test_id}} {{op_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Health",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "max(etcd_benchmark_exporter_up{test_id=~\"$test_id\"}) > bool 0",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "DOWN",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Elapsed Time",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum(etcd_benchmark_elapsed_seconds_total{test_id=~\"$test_id\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "unit": "s"
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Read Ops",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum(etcd_benchmark_read_ops_total{test_id=~\"$test_id\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Write Ops",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum(etcd_benchmark_write_ops_total{test_id=~\"$test_id\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheusds}"
          },
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    }
  ]
}
